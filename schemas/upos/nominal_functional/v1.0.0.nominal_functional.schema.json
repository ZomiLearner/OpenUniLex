{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://OpenUniLex.org/schemas/upos/nominal_functional/v1.0.0.nominal_functional.schema.json",
  "type": "object",
  "properties": {
    "pos_payload": {
      "type": "object",
      "properties": {
        "functional_scope": {
          "type": "string",
          "enum": [
            "DEICTIC",
            "PERSONAL",
            "QUANTIFIER",
            "CARDINAL"
          ]
        },
        "token_class": {
          "type": "string",
          "enum": [
            "pronoun",
            "determiner",
            "quantifier",
            "cardinal"
          ]
        },
        "gender": {
          "type": "string"
        },
        "case": {
          "type": "string"
        },
        "surface_forms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "usage_notes": {
          "type": "string"
        },
        "structural_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": ""
        }
      },
      "required": [
        "functional_scope",
        "token_class",
        "surface_forms"
      ],
      "additionalProperties": false
    }
  }
}