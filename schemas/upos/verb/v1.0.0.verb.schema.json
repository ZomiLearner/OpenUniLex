{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://OpenUniLex.org/schemas/upos/verb/v1.0.0.verb.schema.json",
  "type": "object",
  "properties": {
    "pos_payload": {
      "type": "object",

      "properties": {
        "stem_alternations": {
          "type": "object",
          "properties": {
            "stem_i": {
              "type": "string"
            },
            "stem_ii": {
              "type": "string"
            }
          },
          "required": [
            "stem_i"
          ],
          "additionalProperties": false
        },
        "examples": {
          "type": "array",
          "items": {
            "$ref": "https://OpenUniLex.org/schemas/shared/igt_example/v1.0.0.igt_example.schema.json"
          }
        }
      },
      "required": [
        "stem_alternations",
        "examples"
      ]
    }
  }
}